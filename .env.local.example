# --- AI provider (set ONE of these) ---

# Recommended: Vercel AI Gateway. Free $5 credit, multi-provider, observability.
# Get key: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# Or direct Anthropic key (used as fallback if gateway not set):
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model. Default: anthropic/claude-sonnet-4-6 via gateway.
# AI_MODEL=anthropic/claude-sonnet-4-6

# --- Auth (Clerk) — optional ---
# Without these the app runs in guest-only mode. To enable sign-in,
# create an application at https://dashboard.clerk.com and paste:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# --- Vision via Google AI Studio (Gemma 4 multimodal) ---
# Required for the "Build course from photo" feature. Free tier is generous
# enough for development and the Gemma 4 Good Hackathon submission demo.
# Get key: https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy...

# --- Database (Turso) — required for PRODUCTION only ---
# Local dev uses a file at .data/app.db automatically. For Vercel
# deploy (filesystem is read-only), provision a Turso DB:
#   1. Sign up at https://turso.tech
#   2. turso db create mnemo
#   3. turso db show mnemo --url     → put as TURSO_DATABASE_URL
#   4. turso db tokens create mnemo  → put as TURSO_AUTH_TOKEN
# TURSO_DATABASE_URL=libsql://mnemo-yourname.turso.io
# TURSO_AUTH_TOKEN=eyJhbGc...
