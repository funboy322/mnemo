# --- AI provider (set ONE of these) ---

# Recommended: Vercel AI Gateway. Free $5 credit, multi-provider, observability.
# Get key: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# Or direct Anthropic key (used as fallback if gateway not set):
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model. Default: anthropic/claude-sonnet-4-6 via gateway.
# AI_MODEL=anthropic/claude-sonnet-4-6
